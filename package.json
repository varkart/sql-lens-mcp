{
  "name": "mcp-sql-explorer",
  "version": "2.0.0",
  "description": "AI-native SQL client built on Model Context Protocol - Query databases using natural language through any LLM",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-sql-explorer": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:ui": "node build-ui.js",
    "build:all": "npm run build && npm run build:ui",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "npm run build && tsc -p tsconfig.test.json && mocha --require test/setup.js 'test-dist/**/*.test.js'",
    "test:integration": "npm run build && tsc -p tsconfig.test.json && mocha --require test/setup.js 'test-dist/integration/**/*.test.js' --timeout 60000",
    "test:unit": "npm run build && tsc -p tsconfig.test.json && mocha --require test/setup.js 'test-dist/unit/**/*.test.js'",
    "test:watch": "npm test -- --watch",
    "lint": "eslint src --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sql",
    "database",
    "postgresql",
    "mysql",
    "sqlite",
    "mssql",
    "oracle",
    "mariadb",
    "natural-language",
    "ai",
    "llm",
    "claude",
    "chatgpt",
    "database-management",
    "query-builder",
    "schema-introspection"
  ],
  "author": {
    "name": "vk",
    "url": "https://github.com/varkart"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/varkart/mcp-sql-explorer.git"
  },
  "bugs": {
    "url": "https://github.com/varkart/mcp-sql-explorer/issues"
  },
  "homepage": "https://github.com/varkart/mcp-sql-explorer#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/varkart"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.11.1",
    "mariadb": "^3.5.3",
    "mssql": "^12.6.0",
    "mysql2": "^3.22.5",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/mssql": "^12.3.0",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "chai": "^6.2.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "mocha": "^11.7.6",
    "prettier": "^3.9.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "testcontainers": "^12.0.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  },
  "optionalDependencies": {
    "oracledb": "^7.0.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "hono": "^4.12.21",
    "@hono/node-server": "^1.19.13",
    "qs": "^6.15.2",
    "fast-uri": "^3.1.2",
    "ip-address": "^10.1.1",
    "protobufjs": "^7.5.6",
    "@protobufjs/utf8": "^1.1.1",
    "uuid": "^11.1.1",
    "tmp": "^0.2.6",
    "undici": "^6.24.0"
  }
}
